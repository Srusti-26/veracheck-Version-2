# VeraCheck Backend — Environment Variables
# Copy to .env and edit as needed

# App
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Redis (optional — falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379

# Embedding model (multilingual, supports Hindi/Kannada/Tamil/etc.)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LLM — choose one:
# Low compute (CPU):  google/flan-t5-base
# Medium (GPU 8GB):   mistralai/Mistral-7B-Instruct-v0.2
# Medium (GPU 6GB):   meta-llama/Llama-3.2-3B-Instruct
LLM_MODEL=google/flan-t5-base

# Pipeline thresholds (tune to trade accuracy vs LLM usage)
HIGH_SIM_THRESHOLD=0.88
MID_SIM_THRESHOLD=0.65

# Feed simulator
FEED_POSTS_PER_SECOND=10.0

# FAISS
FAISS_TOP_K=5
